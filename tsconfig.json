{
  "compilerOptions": {
    "target":                    "ES2020",
    "lib":                       ["ES2020", "dom", "dom.iterable"],
    "types":                     ["node"],
    "module":                    "CommonJS",
    "moduleResolution":          "node",
    "jsx":                       "react-native",
    "strict":                    true,
    "noImplicitAny":             true,
    "strictNullChecks":          true,
    "esModuleInterop":           true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule":         true,
    "skipLibCheck":              true,
    "outDir":                    "./dist",
    "rootDir":                   "./",
    "baseUrl":                   ".",
    "paths": {
      "@src/*":      ["src/*"],
      "@screens/*": ["src/screens/*"],
      "@api/*":      ["src/api/*"],
      "@algorithm/*":["src/algorithm/*"],
      "@store/*":    ["src/store/*"],
      "@utils/*":    ["src/utils/*"],
      "@db/*":       ["src/database/*"],
      "@services/*": ["src/services/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "__tests__/**/*", "App.tsx"],
  "exclude": ["node_modules", "android", "ios", "dist"]
}
