{
  "name": "CourtIQ",
  "version": "1.0.0",
  "description": "NBA PG Analytics & Prop-Betting Intelligence Platform — Bayesian 13-factor algorithm",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android":    "react-native run-android",
    "start":      "react-native start",
    "web":        "npx serve web",
    "test":       "jest --forceExit",
    "lint":       "eslint src --ext .ts,.tsx",
    "backtest":   "ts-node scripts/runBacktest.ts",
    "typecheck":  "tsc --noEmit"
  },
  "dependencies": {
    "react":                               "18.3.1",
    "react-native":                        "0.76.5",
    "@react-navigation/native":            "^6.1.18",
    "@react-navigation/bottom-tabs":       "^6.6.1",
    "@react-native-community/slider":      "^4.5.5",
    "@reduxjs/toolkit":                    "^2.3.0",
    "react-redux":                         "^9.1.2",
    "axios":                               "^1.7.7",
    "react-native-safe-area-context":      "^4.12.0",
    "react-native-screens":                "^4.3.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "react-native-sqlite-storage":         "^6.0.1",
    "react-native-vector-icons":           "^10.2.0"
  },
  "devDependencies": {
    "@babel/core":                         "^7.25.0",
    "@babel/preset-env":                   "^7.25.0",
    "@babel/preset-typescript":            "^7.25.0",
    "@types/jest":                         "^29.5.13",
    "@types/react":                        "~18.3.1",
    "@types/react-native":                 "^0.73.0",
    "@types/node":                         "^22.0.0",
    "typescript":                          "^5.5.4",
    "ts-node":                             "^10.9.2",
    "jest":                                "^29.7.0",
    "babel-jest":                          "^29.7.0",
    "eslint":                              "^8.57.1",
    "@typescript-eslint/eslint-plugin":    "^7.18.0",
    "@typescript-eslint/parser":           "^7.18.0"
  },
  "jest": {
    "preset":          "react-native",
    "testPathPattern": "__tests__",
    "transform": {
      "^.+\\.(ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-redux|@reduxjs)/)"
    ],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "setupFilesAfterFramework": []
  },
  "engines": {
    "node": ">=18"
  }
}
